# Localia frontend environment contract.
# Copy to `.env.local` and fill in real values. Do NOT commit `.env.local`.

# Backend origin the Next.js dev proxy/rewrite forwards "/api/..." requests to.
# Defaults to http://localhost:4000 when unset.
API_PROXY_TARGET=http://localhost:4000

# Public base URL of the deployed app. Used for metadata, sitemap, robots and
# canonical/OG URLs. Defaults to https://localia.app when unset.
APP_URL=http://localhost:3000

# One-click demo login credentials surfaced on the login page. When a role's
# email AND password are both set, its demo button appears. Leave blank to hide.

# Demo CLIENT account (browses providers, leaves reviews).
NEXT_PUBLIC_DEMO_CLIENT_EMAIL=client@example.com
NEXT_PUBLIC_DEMO_CLIENT_PASSWORD=changeme

# Demo PROVIDER account (manages a business profile in the dashboard).
NEXT_PUBLIC_DEMO_PROVIDER_EMAIL=provider@example.com
NEXT_PUBLIC_DEMO_PROVIDER_PASSWORD=changeme

# Demo ADMIN account (moderation queue, providers, categories).
NEXT_PUBLIC_DEMO_ADMIN_EMAIL=admin@example.com
NEXT_PUBLIC_DEMO_ADMIN_PASSWORD=changeme
